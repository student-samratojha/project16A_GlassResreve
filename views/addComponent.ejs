<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GlassReserve - <%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background-color: #050505;
            background-image:
                radial-gradient(circle at 0% 0%, rgba(59, 130, 246, 0.15) 0%, transparent 45%),
                radial-gradient(circle at 100% 100%, rgba(147, 51, 234, 0.15) 0%, transparent 45%);
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-6 text-slate-200">
    <div class="w-full max-w-2xl glass-card rounded-[2rem] p-10">
        <div class="mb-10 text-center">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-3xl bg-purple-600/15 border border-purple-500/30 mb-6">
                <svg class="w-8 h-8 text-purple-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6l4 2"></path></svg>
            </div>
            <h1 class="text-3xl font-bold tracking-tight text-white mb-2">GlassReserve - <%= title %></h1>
            <p class="text-slate-400 text-sm">Create components with the same polished glass UI style.</p>
        </div>

        <% if (typeof success !== 'undefined' && success == '1') { %>
            <div class="bg-green-600/20 text-white p-4 rounded-3xl mb-6 border border-green-500/20">Component added successfully!</div>
        <% } %>

        <form action="/component/add" method="POST" class="space-y-5 glass-card rounded-[1.5rem] p-8">
            <div>
                <label for="name" class="block text-xs font-semibold uppercase tracking-widest text-slate-400 mb-2">Name</label>
                <input type="text" id="name" name="name" required class="w-full bg-white/5 border border-white/10 rounded-3xl px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-purple-500/40 transition-all">
            </div>
            <div>
                <label for="type" class="block text-xs font-semibold uppercase tracking-widest text-slate-400 mb-2">Type</label>
                <input type="text" id="type" name="type" required class="w-full bg-white/5 border border-white/10 rounded-3xl px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-purple-500/40 transition-all">
            </div>
            <div>
                <label for="description" class="block text-xs font-semibold uppercase tracking-widest text-slate-400 mb-2">Description</label>
                <textarea id="description" name="description" rows="4" class="w-full bg-white/5 border border-white/10 rounded-3xl px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-purple-500/40 transition-all"></textarea>
            </div>
            <div>
                <label for="status" class="block text-xs font-semibold uppercase tracking-widest text-slate-400 mb-2">Status</label>
                <select id="status" name="status" required class="w-full bg-white/5 border border-white/10 rounded-3xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-purple-500/40 transition-all">
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                </select>
            </div>
            <div>
                <label for="image" class="block text-xs font-semibold uppercase tracking-widest text-slate-400 mb-2">Image URL</label>
                <input type="url" id="image" name="image" class="w-full bg-white/5 border border-white/10 rounded-3xl px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-purple-500/40 transition-all">
            </div>
            <button type="submit" class="w-full bg-purple-600 hover:bg-purple-500 text-white font-bold py-3 rounded-3xl transition duration-300 shadow-lg shadow-purple-600/20">Add Component</button>
        </form>

        <p class="mt-8 text-center text-slate-400">Back to <a href="/secure/admin" class="text-blue-400 hover:text-blue-300 font-medium">Dashboard</a></p>
    </div>
</body>
</html>