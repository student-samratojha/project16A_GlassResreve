<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GlassReserve - <%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background-color: #050505;
            background-image:
                radial-gradient(circle at 0% 0%, rgba(59, 130, 246, 0.15) 0%, transparent 45%),
                radial-gradient(circle at 100% 100%, rgba(147, 51, 234, 0.15) 0%, transparent 45%);
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-6 text-slate-200">
    <div class="w-full max-w-7xl glass-card rounded-[2rem] p-10">
        <div class="mb-8 flex flex-col gap-4 md:flex-row md:justify-between md:items-center">
            <div>
                <h1 class="text-3xl font-bold tracking-tight text-white mb-2">GlassReserve - <%= title %></h1>
                <p class="text-slate-400">Welcome, <%= admin.username %>!</p>
            </div>
            <a href="/auth/logout" class="inline-flex items-center justify-center bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-6 rounded-3xl transition duration-300">Logout</a>
        </div>

        <% if (typeof success !== 'undefined' && success == '1') { %>
            <div class="bg-green-600/20 text-white p-4 rounded-3xl mb-6 border border-green-500/20">Action completed successfully!</div>
        <% } %>

        <div class="glass-card rounded-[1.75rem] p-6 mb-6 border border-white/10">
            <div class="flex flex-wrap gap-4">
                <a href="/component/add" class="inline-flex items-center justify-center bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 px-6 rounded-3xl transition duration-300">Add Component</a>
            </div>
        </div>

        <div class="glass-card rounded-[1.75rem] p-6 mb-6 border border-white/10">
            <h2 class="text-2xl font-semibold mb-4">Users</h2>
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-white/10 bg-white/5 rounded-3xl overflow-hidden">
                    <thead class="bg-white/10">
                        <tr>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300">Username</th>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300">Email</th>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300">Role</th>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300">Status</th>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/10">
                        <% users.forEach(user => { %>
                            <tr class="hover:bg-white/5 transition-colors">
                                <td class="px-4 py-3 text-sm text-white"><%= user.username %></td>
                                <td class="px-4 py-3 text-sm text-slate-300"><%= user.email %></td>
                                <td class="px-4 py-3 text-sm text-slate-300 capitalize"><%= user.role %></td>
                                <td class="px-4 py-3 text-sm text-slate-300 capitalize"><%= user.isActive %></td>
                                <td class="px-4 py-3 text-sm">
                                    <% if (user.status === 'active') { %>
                                        <form action="/secure/delete" method="POST" class="inline">
                                            <input type="hidden" name="id" value="<%= user._id %>">
                                            <button type="submit" class="bg-red-600 hover:bg-red-700 text-white font-semibold py-2 px-4 rounded-3xl transition duration-300">Delete</button>
                                        </form>
                                    <% } else { %>
                                        <form action="/secure/restore" method="POST" class="inline">
                                            <input type="hidden" name="id" value="<%= user._id %>">
                                            <button type="submit" class="bg-green-600 hover:bg-green-700 text-white font-semibold py-2 px-4 rounded-3xl transition duration-300">Restore</button>
                                        </form>
                                    <% } %>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="glass-card rounded-[1.75rem] p-6 mb-6 border border-white/10">
            <h2 class="text-2xl font-semibold mb-4">Components</h2>
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-white/10 bg-white/5 rounded-3xl overflow-hidden">
                    <thead class="bg-white/10">
                        <tr>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300">Name</th>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300">Type</th>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300">Status</th>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300">Created</th>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/10">
                      
                        <% components.forEach(component => { %>
                            <tr class="hover:bg-white/5 transition-colors">
                                <td class="px-4 py-3 text-sm text-white"><%= component.name %></td>
                                <td class="px-4 py-3 text-sm text-slate-300"><%= component.type %></td>
                                <td class="px-4 py-3 text-sm text-slate-300"><%= component.status %></td>
                                <td class="px-4 py-3 text-sm text-slate-300"><%= new Date(component.createdAt).toLocaleDateString() %></td>
                                <td class="px-4 py-3 text-sm">
                                    <a href="/component/edit/<%= component._id %>" class="inline-flex items-center justify-center bg-blue-600 hover:bg-blue-500 text-white font-semibold py-2 px-4 rounded-3xl transition duration-300 mr-2">Edit</a>
                                    <% if (component.status === 'active') { %>
                                        <form action="/component/delete" method="POST" class="inline">
                                            <input type="hidden" name="id" value="<%= component._id %>">
                                            <button type="submit" class="bg-red-600 hover:bg-red-700 text-white font-semibold py-2 px-4 rounded-3xl transition duration-300">Delete</button>
                                        </form>
                                    <% } else { %>
                                        <form action="/component/restore" method="POST" class="inline">
                                            <input type="hidden" name="id" value="<%= component._id %>">
                                            <button type="submit" class="bg-green-600 hover:bg-green-700 text-white font-semibold py-2 px-4 rounded-3xl transition duration-300">Restore</button>
                                        </form>
                                    <% } %>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="glass-card rounded-[1.75rem] p-6 mb-6 border border-white/10">
            <h2 class="text-2xl font-semibold mb-4">Bookings</h2>
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-white/10 bg-white/5 rounded-3xl overflow-hidden">
                    <thead class="bg-white/10">
                        <tr>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300">User</th>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300">Component</th>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300">Start</th>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300">End</th>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300">Status</th>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/10">
                          <% if (bookings.length === 0) { %>
                            <tr>
                                <td colspan="5" class="px-4 py-3 text-center text-sm text-slate-400">No components found.</td>
                            </tr>
                        <% } %>
                        <% bookings.forEach(booking => { %>
                            <tr class="hover:bg-white/5 transition-colors">
                                <td class="px-4 py-3 text-sm text-white"><%= booking.user ? booking.user.username : 'Unknown' %></td>
                                <td class="px-4 py-3 text-sm text-slate-300"><%= booking.component ? booking.component.name : 'Unknown' %></td>
                                <td class="px-4 py-3 text-sm text-slate-300"><%= new Date(booking.startDate).toLocaleDateString() %></td>
                                <td class="px-4 py-3 text-sm text-slate-300"><%= new Date(booking.endDate).toLocaleDateString() %></td>
                                <td class="px-4 py-3 text-sm text-slate-300"><%= booking.status %></td>
                                <td class="px-4 py-3 text-sm space-y-2">
                                    <% if (booking.status !== 'confirmed') { %>
                                        <form action="/booking/confirm" method="POST" class="inline-block">
                                            <input type="hidden" name="id" value="<%= booking._id %>">
                                            <button type="submit" class="bg-blue-600 hover:bg-blue-500 text-white font-semibold py-2 px-4 rounded-3xl transition duration-300 mr-2">Confirm</button>
                                        </form>
                                    <% } %>
                                    <% if (booking.status === 'confirmed') { %>
                                        <form action="/booking/complete" method="POST" class="inline-block">
                                            <input type="hidden" name="id" value="<%= booking._id %>">
                                            <button type="submit" class="bg-green-600 hover:bg-green-700 text-white font-semibold py-2 px-4 rounded-3xl transition duration-300 mr-2">Complete</button>
                                        </form>
                                    <% } %>
                                    <% if (booking.status !== 'cancelled') { %>
                                        <form action="/booking/cancel" method="POST" class="inline-block">
                                            <input type="hidden" name="id" value="<%= booking._id %>">
                                            <button type="submit" class="bg-red-600 hover:bg-red-700 text-white font-semibold py-2 px-4 rounded-3xl transition duration-300">Cancel</button>
                                        </form>
                                    <% } %>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="glass-card rounded-[1.75rem] p-6 border border-white/10">
            <h2 class="text-2xl font-semibold mb-4">Recent Audits</h2>
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-white/10 bg-white/5 rounded-3xl overflow-hidden">
                    <thead class="bg-white/10">
                        <tr>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300">User</th>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300">Action</th>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300">Route</th>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300">Method</th>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300">IP</th>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300">Date</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/10">
                        <% audits.forEach(audit => { %>
                            <tr class="hover:bg-white/5 transition-colors">
                                <td class="px-4 py-3 text-sm text-white"><%= audit.user ? audit.user.username : 'N/A' %></td>
                                <td class="px-4 py-3 text-sm text-slate-300"><%= audit.action %></td>
                                <td class="px-4 py-3 text-sm text-slate-300"><%= audit.route %></td>
                                <td class="px-4 py-3 text-sm text-slate-300"><%= audit.method %></td>
                                <td class="px-4 py-3 text-sm text-slate-300"><%= audit.ip %></td>
                                <td class="px-4 py-3 text-sm text-slate-300"><%= new Date(audit.createdAt).toLocaleString() %></td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>