<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GlassReserve - <%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background-color: #050505;
            background-image:
                radial-gradient(circle at 0% 0%, rgba(59, 130, 246, 0.15) 0%, transparent 45%),
                radial-gradient(circle at 100% 100%, rgba(147, 51, 234, 0.15) 0%, transparent 45%);
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-6 text-slate-200">
    <div class="w-full max-w-5xl glass-card rounded-[2rem] p-10">
        <div class="mb-8 flex flex-col gap-4 md:flex-row md:justify-between md:items-center">
            <div>
                <h1 class="text-3xl font-bold tracking-tight text-white mb-2">GlassReserve - <%= title %></h1>
                <p class="text-slate-400">Welcome, <%= user.username %>!</p>
            </div>
            <a href="/auth/logout" class="inline-flex items-center justify-center bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-6 rounded-3xl transition duration-300">Logout</a>
        </div>

        <% if (typeof success !== 'undefined' && success == '1') { %>
            <div class="bg-green-600/20 text-white p-4 rounded-3xl mb-6 border border-green-500/20">Action completed successfully!</div>
        <% } %>

        <% if (typeof Welcome !== 'undefined') { %>
            <div class="bg-green-600/20 text-white p-4 rounded-3xl mb-6 border border-green-500/20">Welcome, <%= Welcome %>!</div>
        <% } %>

        <div class="glass-card rounded-[1.75rem] p-6 mb-6 border border-white/10">
            <a href="/booking/add" class="inline-flex items-center justify-center bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 px-6 rounded-3xl transition duration-300">Add Booking</a>
        </div>

        <div class="glass-card rounded-[1.75rem] p-6 mb-6 border border-white/10">
            <h2 class="text-2xl font-semibold mb-4">Your Profile</h2>
            <div class="grid gap-4 sm:grid-cols-2">
                <div class="rounded-3xl bg-white/5 p-4 border border-white/10">
                    <p class="text-slate-400 text-sm">Role</p>
                    <p class="text-white font-semibold"><%= user.role %></p>
                </div>
                <div class="rounded-3xl bg-white/5 p-4 border border-white/10">
                    <p class="text-slate-400 text-sm">Email</p>
                    <p class="text-white font-semibold"><%= user.email %></p>
                </div>
            </div>
        </div>

        <div class="glass-card rounded-[1.75rem] p-6 border border-white/10">
            <h2 class="text-2xl font-semibold mb-4">My Bookings</h2>
            <% if (bookings && bookings.length > 0) { %>
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-white/10 bg-white/5 rounded-3xl overflow-hidden">
                        <thead class="bg-white/10">
                            <tr>
                                <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300">Component</th>
                                <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300">Start</th>
                                <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300">End</th>
                                <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300">Status</th>
                                <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-white/10">
                            <% bookings.forEach(booking => { %>
                                <tr class="hover:bg-white/5 transition-colors">
                                    <td class="px-4 py-3 text-sm text-white"><%= booking.component ? booking.component.name : 'Unknown' %></td>
                                    <td class="px-4 py-3 text-sm text-slate-300"><%= new Date(booking.startDate).toLocaleDateString() %></td>
                                    <td class="px-4 py-3 text-sm text-slate-300"><%= new Date(booking.endDate).toLocaleDateString() %></td>
                                    <td class="px-4 py-3 text-sm text-slate-300"><%= booking.status %></td>
                                    <td class="px-4 py-3 text-sm space-y-2">
                                        <% if (booking.status !== 'cancelled') { %>
                                            <form action="/booking/cancel" method="POST" class="inline">
                                                <input type="hidden" name="id" value="<%= booking._id %>">
                                                <button type="submit" class="bg-red-600 hover:bg-red-700 text-white font-semibold py-2 px-4 rounded-3xl transition duration-300">Cancel</button>
                                            </form>
                                        <% } else { %>
                                            <span class="inline-flex items-center rounded-3xl bg-slate-700 px-3 py-2 text-sm text-slate-300">Cancelled</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <p class="text-slate-400">You have no bookings yet. Create one to get started.</p>
            <% } %>
        </div>
    </div>
</body>
</html>