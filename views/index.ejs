<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GlassReserve - <%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      body {
        background-color: #050505;
        background-image:
          radial-gradient(
            circle at 0% 0%,
            rgba(59, 130, 246, 0.15) 0%,
            transparent 45%
          ),
          radial-gradient(
            circle at 100% 100%,
            rgba(147, 51, 234, 0.15) 0%,
            transparent 45%
          );
      }
      .glass-card {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
      }
    </style>
  </head>
  <body
    class="min-h-screen flex items-center justify-center p-6 text-slate-200"
  >
    <div class="w-full max-w-3xl glass-card rounded-[2rem] p-10">
      <div class="mb-10 text-center">
        <div
          class="inline-flex items-center justify-center w-16 h-16 rounded-3xl bg-blue-600/15 border border-blue-500/30 mb-6"
        >
          <svg
            class="w-8 h-8 text-blue-400"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M12 6v6l4 2"
            ></path>
          </svg>
        </div>
        <h1 class="text-4xl font-bold tracking-tight text-white mb-3">
          GlassReserve
        </h1>
        <p class="text-slate-400 text-base">
          A sleek component booking system with glass UI design.
        </p>
      </div>

      <!-- Features Section -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-white mb-6 text-center">
          Key Features
        </h2>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          <div class="glass-card rounded-2xl p-6 text-center">
            <div
              class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-blue-600/20 border border-blue-500/30 mb-4"
            >
              <svg
                class="w-6 h-6 text-blue-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                ></path>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-white mb-2">
              Secure Authentication
            </h3>
            <p class="text-slate-400 text-sm">
              JWT-based login with role-based access control for users and
              admins.
            </p>
          </div>
          <div class="glass-card rounded-2xl p-6 text-center">
            <div
              class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-purple-600/20 border border-purple-500/30 mb-4"
            >
              <svg
                class="w-6 h-6 text-purple-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
                ></path>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-white mb-2">
              Component Management
            </h3>
            <p class="text-slate-400 text-sm">
              Add, edit, and manage components with images, types, and
              descriptions.
            </p>
          </div>
          <div class="glass-card rounded-2xl p-6 text-center">
            <div
              class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-green-600/20 border border-green-500/30 mb-4"
            >
              <svg
                class="w-6 h-6 text-green-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                ></path>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-white mb-2">
              Booking System
            </h3>
            <p class="text-slate-400 text-sm">
              Easy booking of components with date selection and status
              tracking.
            </p>
          </div>
          <div class="glass-card rounded-2xl p-6 text-center">
            <div
              class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-red-600/20 border border-red-500/30 mb-4"
            >
              <svg
                class="w-6 h-6 text-red-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-white mb-2">
              Admin Dashboard
            </h3>
            <p class="text-slate-400 text-sm">
              Comprehensive admin panel to manage users, bookings, and audit
              logs.
            </p>
          </div>
          <div class="glass-card rounded-2xl p-6 text-center">
            <div
              class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-yellow-600/20 border border-yellow-500/30 mb-4"
            >
              <svg
                class="w-6 h-6 text-yellow-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 100 4m0-4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 100 4m0-4v2m0-6V4"
                ></path>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-white mb-2">Audit Logging</h3>
            <p class="text-slate-400 text-sm">
              Track all actions with detailed audit logs for security and
              compliance.
            </p>
          </div>
          <div class="glass-card rounded-2xl p-6 text-center">
            <div
              class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-indigo-600/20 border border-indigo-500/30 mb-4"
            >
              <svg
                class="w-6 h-6 text-indigo-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
                ></path>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-white mb-2">
              Glass UI Theme
            </h3>
            <p class="text-slate-400 text-sm">
              Beautiful macOS-inspired glass design with blur effects and
              gradients.
            </p>
          </div>
        </div>
      </div>

      <!-- Workflow Section -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-white mb-6 text-center">
          How It Works
        </h2>
        <div class="space-y-6">
          <div class="glass-card rounded-2xl p-6 flex items-center">
            <div
              class="flex-shrink-0 w-12 h-12 rounded-2xl bg-blue-600/20 border border-blue-500/30 flex items-center justify-center mr-4"
            >
              <span class="text-blue-400 font-bold">1</span>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-white mb-1">
                Register or Login
              </h3>
              <p class="text-slate-400 text-sm">
                Create an account or sign in with your credentials to access the
                system.
              </p>
            </div>
          </div>
          <div class="glass-card rounded-2xl p-6 flex items-center">
            <div
              class="flex-shrink-0 w-12 h-12 rounded-2xl bg-purple-600/20 border border-purple-500/30 flex items-center justify-center mr-4"
            >
              <span class="text-purple-400 font-bold">2</span>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-white mb-1">
                Browse Components
              </h3>
              <p class="text-slate-400 text-sm">
                View available components with details, images, and types.
              </p>
            </div>
          </div>
          <div class="glass-card rounded-2xl p-6 flex items-center">
            <div
              class="flex-shrink-0 w-12 h-12 rounded-2xl bg-green-600/20 border border-green-500/30 flex items-center justify-center mr-4"
            >
              <span class="text-green-400 font-bold">3</span>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-white mb-1">
                Make a Booking
              </h3>
              <p class="text-slate-400 text-sm">
                Select dates and book components directly from the interface.
              </p>
            </div>
          </div>
          <div class="glass-card rounded-2xl p-6 flex items-center">
            <div
              class="flex-shrink-0 w-12 h-12 rounded-2xl bg-red-600/20 border border-red-500/30 flex items-center justify-center mr-4"
            >
              <span class="text-red-400 font-bold">4</span>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-white mb-1">
                Manage & Monitor
              </h3>
              <p class="text-slate-400 text-sm">
                Admins can oversee users, bookings, and audits; users can manage
                their bookings.
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="space-y-4">
        <a
          href="/auth/login"
          class="block w-full text-center bg-blue-600 hover:bg-blue-500 transition duration-300 text-white font-semibold py-3 rounded-3xl shadow-lg shadow-blue-600/20"
          >Login</a
        >
        <a
          href="/auth/register"
          class="block w-full text-center bg-purple-600 hover:bg-purple-500 transition duration-300 text-white font-semibold py-3 rounded-3xl shadow-lg shadow-purple-600/20"
          >Register</a
        >
      </div>
    </div>
  </body>
</html>
